# ---- Event media CDN (GitHub repo -> Statically CDN) ----
# These point the site at the event-media repository. Defaults are baked in
# (noicehax/ssfimages@main), so you only need to set these to override.
# Used by both the app (src/config/cdn.ts) and the build-time discovery
# script (scripts/generate-events.mjs).

NEXT_PUBLIC_GH_USERNAME=noicehax
NEXT_PUBLIC_GH_REPO=ssfimages
NEXT_PUBLIC_GH_BRANCH=main

# Optional: a GitHub token raises the build-time discovery rate limit
# (60/hr -> 5000/hr). Not required for normal builds.
# GITHUB_TOKEN=
